{
	"name": "fluxify",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently 'bun run dev:server' 'bun run dev:web' 'bun run dev:ai' 'bun run dev:docs'",
		"dev:server": "bun run --env-file=./apps/server/.env --watch ./apps/server/deployments/standalone.ts",
		"dev:ai": "bun run --env-file=./apps/ai-gateway/.env --watch ./apps/ai-gateway/src/server.ts",
		"dev:web": "turbo run dev --filter=@fluxify/web",
		"dev:docs": "vitepress dev docs",
		"lint": "turbo run lint",
		"build": "turbo run build",
		"test:unit": "bun test --path-ignore-patterns \"**/*.test.ts\"",
		"test:integration": "bun test --parallel --path-ignore-patterns \"**/*.spec.ts\"",
		"test:lib": "bun run --parallel --cwd packages/lib test",
		"test:blocks": "bun run --parallel --cwd packages/blocks test",
		"test:adapters": "bun run --parallel --cwd packages/adapters test",
		"test:server:unit": "bun test --parallel --cwd apps/server --path-ignore-patterns \"**/*.test.ts\"",
		"test:server:integration": "bun test --parallel --cwd apps/server --path-ignore-patterns \"**/*.spec.ts\"",
		"build:ai": "turbo run build --filter=@fluxify/ai-gateway",
		"analyze": "bun x fta-cli --score-cap 70 .",
		"security:scan": "bun x secretlint --format compact \"**/*\"",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"prepare": "bun run scripts/setup-hooks.ts",
		"db:generate": "bun --cwd ./apps/server drizzle-kit generate",
		"db:migrate": "bun --cwd ./apps/server drizzle-kit push"
	},
	"keywords": [
		"fluxify",
		"@fluxify"
	],
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"packageManager": "bun@1.3.14",
	"author": "07prajwal2000",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"@orama/orama": "^3.1.18",
		"better-auth": "1.6.23",
		"http-proxy": "^1.18.1"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@secretlint/secretlint-rule-preset-recommend": "^13.0.4",
		"@types/bun": "^1.3.9",
		"@types/dockerode": "^4.0.1",
		"@typescript/native-preview": "^7.0.0-dev.20260219.1",
		"concurrently": "^9.2.1",
		"dockerode": "^4.0.9",
		"fta-cli": "^3.0.0",
		"secretlint": "^13.0.4",
		"turbo": "^2.5.5",
		"ui-ux-pro-max-cli": "^2.10.2",
		"vitepress": "^1.6.4"
	},
	"trustedDependencies": [
		"@faker-js/faker",
		"@swc/core",
		"@typescript/native-preview",
		"esbuild",
		"sharp"
	],
	"resolutions": {
		"bson": "7.2.0",
		"ansi-regex": "5.0.1"
	},
	"overrides": {
		"ansi-regex": "5.0.1"
	}
}
