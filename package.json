{
	"name": "fluxify",
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "concurrently 'bun run dev:server' 'bun run dev:web' 'bun run dev:ai'",
		"dev:server": "bun run --env-file=./apps/server/.env --watch ./apps/server/deployments/standalone.ts",
		"dev:ai": "bun run --env-file=./apps/ai-gateway/.env --watch ./apps/ai-gateway/src/index.ts",
		"dev:web": "turbo run dev --filter=@fluxify/web",
		"dev:proxy": "bun run --watch ./scripts/proxy.js ./scripts/config.json",
		"lint": "turbo run lint",
		"build": "turbo run build",
		"test:unit": "bun test --path-ignore-patterns \"**/*.test.ts\"",
		"test:integration": "bun test --path-ignore-patterns \"**/*.spec.ts\"",
		"build:proxy": "bun build scripts/proxy.js --outfile=dist/proxy.js --bundle --target bun --minify",
		"build:ai": "turbo run build --filter=@fluxify/ai-gateway",
		"analyze": "bun x fta-cli --score-cap 70 ."
	},
	"keywords": [
		"fluxify",
		"@fluxify"
	],
	"workspaces": [
		"packages/*",
		"apps/*"
	],
	"packageManager": "bun@1.3.6",
	"author": "07prajwal2000",
	"license": "ISC",
	"description": "",
	"dependencies": {
		"@orama/orama": "^3.1.18",
		"better-auth": "1.6.15",
		"http-proxy": "^1.18.1"
	},
	"devDependencies": {
		"@faker-js/faker": "^10.3.0",
		"@types/bun": "^1.3.9",
		"@types/dockerode": "^4.0.1",
		"@typescript/native-preview": "^7.0.0-dev.20260219.1",
		"concurrently": "^9.2.1",
		"dockerode": "^4.0.9",
		"fta-cli": "^3.0.0",
		"turbo": "^2.5.5"
	},
	"trustedDependencies": [
		"@faker-js/faker",
		"@swc/core",
		"@typescript/native-preview",
		"esbuild",
		"sharp"
	]
}
