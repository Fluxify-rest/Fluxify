# ====================== ENVIRONMENT ======================
# Application runtime mode: development | production
ENVIRONMENT=production
# Node environment mode: development | production
NODE_ENV=production

# ====================== DATABASES ======================
# PostgreSQL connection string: postgres://{username}:{password}@{host}:{port}/{database}
PG_URL=postgres://postgres:postgres@postgres:5432/fluxify_alpha
# Database engine variant: postgres | pglite
DB_VARIANT=postgres
# Local storage directory path when using DB_VARIANT=pglite
DB_PGLITE_PATH=
# Redis cache and queue server host (Valkey container name)
REDIS_HOST=valkey
# Redis server port
REDIS_PORT=6379
# Redis authentication username (optional)
REDIS_USER=
# Redis authentication password (optional)
REDIS_PASS=

# ====================== EVENT BUS (NATS) ======================
# NATS server connection URL (NATS container name)
NATS_URL=nats://nats:4222
# NATS authentication token
NATS_TOKEN=fluxify_nats_token

# ====================== PORT CONFIG & SERVICE URLS ======================
# Next.js web frontend port
WEB_PORT=3000
# Main backend control-plane server port
SERVER_PORT=5500
# Dedicated background worker server port
WORKER_PORT=5600
# Local HTTP proxy server port (Traefik entrypoint)
PROXY_PORT=8080
# AI Gateway service server port
AI_GATEWAY_PORT=8001
# Upstream worker address for admin control-plane proxy routing
WORKER_UPSTREAM=worker:5600
# Public hostname for production deployments (e.g. www.fluxify.rest)
HOSTNAME=0.0.0.0
# Main public server URL
SERVER_URL=http://localhost:8080
# Comma-separated trusted origins for CORS and Better Auth (e.g. http://localhost:8080)
TRUSTED_ORIGINS=http://localhost:8080

# ====================== SECURITY & AUTHENTICATION ======================
# Enable admin control-plane API endpoints (true | false)
ENABLE_ADMIN=true
# Run embedded worker inside standalone server process (true | false)
ENABLE_BUILTIN_WORKER=false
# Enable AI Gateway features and worker integration (true | false)
ENABLE_AI=true
# Master key for encryption (generate via `openssl rand -base64 32`)
MASTER_ENCRYPTION_KEY=ZlhiQmhaS3JSeG5qTDZaWlZMbTd1WDE3aFhvYVlUVjE=
# Live reload route definitions on save (true | false)
HOT_RELOAD_ROUTES=false
# Secret key used for signing Better Auth session tokens
BETTER_AUTH_SECRET=vWJkRKH7tUg31TxgMoknTGTBv4xYFjVM
# Base authentication URL for Better Auth callbacks
BETTER_AUTH_URL=http://localhost:8080
# Machine-to-machine system access key for automated API access
SYSTEM_ACCESS_KEY=2zhJ7KpBp4s6WECoCHsG3ss6SwZuldw6
# Disable npm package installations in execution environment (true | false)
DISABLE_NPM=true
# Default email address for initial admin user seed
SEED_USER_EMAIL=admin@company.com
# Default password for initial admin user seed
SEED_USER_PASSWORD=admin@123
# Default full name for initial admin user seed
SEED_USER_NAME=Admin user

# ====================== PATHS & FILES ======================
# File path to the documentation vector index binary file inside container
DOCS_INDEX_FILE_PATH=/app/ai-gateway/docs-index.bin

# ====================== OPENTELEMETRY LOGGING ======================
# Service identifier for OpenTelemetry telemetry
OTLP_SERVICE_NAME=fluxify.production
# OTLP collector HTTP endpoint URL for log ingestion
OTLP_LOGS_ENDPOINT=http://localhost:5080/api/default/v1/logs
# HTTP header name for OTLP exporter authentication
OTLP_AUTH_HEADER_NAME=Authorization
# HTTP header value for OTLP exporter authentication
OTLP_AUTH_HEADER_VALUE=""
# Enable OpenTelemetry log exporter (true | false)
OTLP_LOGGER_ENABLED=true
# Telemetry log level threshold: info | warn | error
OTLP_LOGGER_LEVEL=info

# ====================== LLM TRACING ======================
# Enable OpenTelemetry tracing for LLM operations (true | false)
LLM_TRACING_ENABLED=true
# OTLP collector HTTP endpoint URL for LLM trace ingestion
LLM_OTLP_TRACES_ENDPOINT=http://localhost:6006/v1/traces
# Additional HTTP headers for LLM trace exporter
LLM_OTLP_TRACES_HEADERS=""
# Sampling rate for LLM traces (0.0 to 1.0)
LLM_TRACING_SAMPLE_RATE=1
