http://localhost:8080 {

    @admin_ui {
        path /_/admin/ui/*
        path /_/admin/ui
    }

    handle @admin_ui {
        reverse_proxy host.docker.internal:3000
    }

    @admin_api path /_/admin/api/*
    @admin_ai path /_/admin/ai/*

    handle @admin_api {
        reverse_proxy host.docker.internal:5500
    }

    handle @admin_ai {
        reverse_proxy host.docker.internal:8001
    }

    handle {
        reverse_proxy host.docker.internal:5500
    }
}
