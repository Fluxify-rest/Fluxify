{
	"name": "@fluxify/server",
	"version": "1.0.0",
	"type": "module",
	"files": [
		"dist"
	],
	"scripts": {
		"dev": "bun --watch deployments/standalone.ts",
		"test": "bun test --concurrent",
		"lint": "tsgo --noEmit",
		"start": "bun run deployments/standalone.ts",
		"build": "bun build deployments/standalone.ts --outdir=dist --bundle --target bun --minify --sourcemap=linked --external @electric-sql/pglite",
		"postbuild": "bun run ./scripts/buildExtras.ts",
		"db:generate": "bun x drizzle-kit generate",
		"db:push": "bun x drizzle-kit push"
	},
	"keywords": [
		"configurable-backend-engine"
	],
	"author": "",
	"license": "ISC",
	"description": "",
	"devDependencies": {
		"@types/bun": "^1.3.14",
		"@types/flexsearch": "^0.7.42",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^26.0.1",
		"@types/pg": "^8.20.0",
		"@types/underscore": "^1.13.0",
		"@typescript/native-preview": "^7.0.0-dev.20260626.1",
		"drizzle-kit": "^0.31.10",
		"pg": "^8.22.0",
		"typescript": "^6.0.3"
	},
	"dependencies": {
		"@electric-sql/pglite": "^0.5.3",
		"@fluxify/adapters": "workspace:*",
		"@fluxify/blocks": "workspace:*",
		"@fluxify/common": "workspace:*",
		"@fluxify/lib": "workspace:*",
		"@hono/standard-validator": "^0.2.2",
		"@hono/zod-validator": "^0.8.0",
		"@langchain/anthropic": "^1.5.1",
		"@langchain/core": "^1.2.1",
		"@langchain/google-genai": "^2.2.0",
		"@langchain/langgraph": "^1.4.7",
		"@langchain/openai": "^1.5.3",
		"@toon-format/toon": "^2.3.0",
		"better-auth": "^1.6.15",
		"dayjs": "^1.11.21",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.44.7",
		"drizzle-zod": "^0.8.3",
		"flexsearch": "^0.8.212",
		"gray-matter": "^4.0.3",
		"hono": "^4.12.27",
		"hono-openapi": "^1.3.0",
		"ioredis": "^5.11.1",
		"jsonwebtoken": "^9.0.3",
		"langchain": "^1.5.2",
		"tokenx": "^1.3.0",
		"underscore": "^1.13.8",
		"yaml": "^2.9.0",
		"zod": "^4.4.3"
	}
}
